# Server
PORT=3001
NODE_ENV=development

# Redis (local: redis://localhost:6379 | Upstash: rediss://...@....upstash.io:6379)
REDIS_URL=redis://localhost:6379

# Storage (absolute path for screenshots)
SCREENSHOT_PATH=/tmp/screenshots

# Security
ALLOWED_ORIGINS=http://localhost:3000
MAX_ZIP_SIZE_MB=500

# Frontend (Next.js)
NEXT_PUBLIC_API_URL=http://localhost:3001
